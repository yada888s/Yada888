<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yada Portfolio</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Merriweather , Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #FFA6C9;
            color: #2c3e50;
            line-height: 1.6;
        }

        header {
            background: #FC8EAC;
            color: #000000;
            padding: 1rem 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .navbar h1 {
            font-size: 1.5rem;
            color: #E0B0FF;
        }

        .nav-links {
            list-style: none;
            display: flex;
        }

        .nav-links li {
            margin-left: 2rem;
        }

        .nav-links a {
            color: #fff;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #E0B0FF;
        }

        .hero {
            background: #A45A52;
            height: 60vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 1rem;
        }
        
        .hero-img{
            width:120px;
            height:120px;
            border-radius:50%;
            object-fit:cover;
            margin-bottom:20px;
            border:4px solid #FFA6C9;
        }

        .hero h2 {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: #FFA6C9;
        }
        
        .hero p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            color: #FFA6C9;
        }

        .btn {
            display: inline-block;
            background: #333333;
            color: #fff;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            transition: background 0.3s;
        }

        .btn:hover {
            background: #FAD1AF;
            color: #333;
        }

        .container {
            max-width: 1100px;
            margin: 3rem auto;
            padding: 0 2rem;
        }

        section {
            margin-bottom: 4rem;
        }

        section h3 {
            font-size: 2rem;
            margin-bottom: 1.5rem;
            text-align: center;
            position: relative;
            color: #FFFFFF;
        }

        section h3::after {
            content: '';
            display: block;
            width: 50px;
            height: 3px;
            background-color: #D8A8A8;
            margin: 0.5rem auto 0 auto;
        }

        .about-content {
            background: #fff;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            width: 70%;
            margin: 0 auto;
            text-align: center;
        }

        .sop-content {
            background: #fff;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            width: 70%;
            margin: 0 auto;
         }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .project-card {
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .project-card:hover {
            transform: translateY(-5px);
        }

        .project-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .project-info {
            padding: 1.5rem;
        }

        .project-info h4 {
            margin-bottom: 0.5rem;
        }

        .project-info p {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 1rem;
        }

        .contact-info {
 
